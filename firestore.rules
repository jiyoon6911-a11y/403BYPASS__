rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definition
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Validation
    function isValidWaitlist(data) {
      return data.keys().hasAll(['email', 'createdAt']) && data.keys().size() == 2 &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt == request.time;
    }

    // Waitlist collection
    match /waitlist/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && 
                    isValidWaitlist(incoming()) && 
                    incoming().email == request.auth.token.email;
    }
  }
}
